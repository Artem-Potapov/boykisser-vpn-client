<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".XtlsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.XTLS_CORE_PROXY">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.XTLS_CORE_PROXY">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!--
                Override the default QS tile long-press behavior (which opens
                the system Settings app-details page) so long-pressing the
                VPN tile opens MainActivity instead. The OS dispatches an
                implicit Intent(ACTION_QS_TILE_PREFERENCES).setPackage(...)
                — DEFAULT category is required for implicit resolution.
            -->
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE_PREFERENCES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".apps.AppPickerActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".split.SplitTunnelSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".killswitch.KillSwitchSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".settings.SettingsHubActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".i18n.LanguageSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".settings.ServerSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".subs.SubscriptionsActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".subs.SubscriptionEditActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".subs.BoykisserInfoActivity"
            android:exported="false"
            android:theme="@style/Theme.XTLS_CORE_PROXY" />

        <activity
            android:name=".subs.BoykisserLinkActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.XTLS_CORE_PROXY">

            <!-- Custom scheme: works without any website/signing setup. -->
            <!-- TEMP: promoted subscription silenced — restore by uncommenting
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bkvpn" android:host="add" />
            </intent-filter>
            -->

            <!-- Verified Android App Link. Requires assetlinks.json hosted on the site with
                 the release signing fingerprint before it auto-verifies (see Task 8). -->
            <!-- TEMP: promoted subscription silenced — restore by uncommenting
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="boykiss3r.site"
                    android:pathPrefix="/app/add" />
            </intent-filter>
            -->
        </activity>

        <service
            android:name=".vpn.XrayVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>

            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn_tunnel_core_proxy" />
        </service>

        <service
            android:name=".tile.XrayVpnTileService"
            android:exported="true"
            android:icon="@drawable/ic_vpn_tile"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

</manifest>